# Match the codebase's existing style — this file is tuned so the initial
# adoption diff stays mechanical.
--swiftversion 6.0
--exclude EdgeDashKit/.build,EdgeDash.xcodeproj,DerivedData

# Existing style: trailing commas in multiline collections, `case .x(let y)`,
# unspaced ranges (`0...1`).
--commas always
--patternlet inline
--ranges no-space

# redundantSelf: Swift 6 actor-isolation makes some "redundant" selfs load-
# bearing; unusedArguments: rewrites protocol-witness signatures to `_`;
# wrapIfStatementBodies/wrapIfExpressionBodies (0.62+): single-line
# `if x { return }` and `if let v = x { v } else { 0 }` are used throughout.
--disable redundantSelf,unusedArguments,wrapIfStatementBodies,wrapIfExpressionBodies
